# ============================================================
# INEED — Environment Variables
# Kopiere diese Datei zu .env.local und fülle die Werte aus
# NIEMALS .env.local in Git committen!
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://DEIN-PROJEKT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...           # Settings > API > anon public
SUPABASE_SERVICE_ROLE_KEY=eyJ...               # Settings > API > service_role (GEHEIM!)

# ── Stripe ───────────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...                  # GEHEIM!
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Mapbox ───────────────────────────────────────────────────
NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ...

# ── Nuki Smart Lock ──────────────────────────────────────────
NUKI_API_TOKEN=...                             # GEHEIM!
NUKI_WEBHOOK_SECRET=...

# ── Livekit (WebRTC) ─────────────────────────────────────────
LIVEKIT_URL=wss://...
LIVEKIT_API_KEY=...
LIVEKIT_API_SECRET=...                         # GEHEIM!

# ── App ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
